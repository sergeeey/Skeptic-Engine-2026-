# Environment Configuration for Skeptic Engine
# Copy this file to .env and fill in your values

# ============================================================
# NCBI E-utilities API
# ============================================================
# NCBI API key (optional but recommended for higher rate limits)
# Get yours at: https://ncbiinsights.ncbi.nlm.nih.gov/2017/11/02/new-api-keys-for-the-e-utilities/
NCBI_API_KEY=your_api_key_here

# Email for NCBI (required by their terms of service)
NCBI_EMAIL=your_email@example.com

# ============================================================
# Semantic Scholar API (for literature search)
# ============================================================
# Optional: for enhanced paper metadata retrieval
SEMANTIC_SCHOLAR_API_KEY=

# ============================================================
# Data Directories
# ============================================================
# Override default data directory (default: ./data)
# SKEPTIC_DATA_DIR=/path/to/data

# Cache directory for downloaded files (default: ./data/cache)
# SKEPTIC_CACHE_DIR=/path/to/cache

# ============================================================
# Experiment Settings
# ============================================================
# Random seed for reproducibility (default: 42)
RANDOM_SEED=42

# Number of parallel workers (default: -1 for all CPUs)
N_JOBS=-1

# ============================================================
# Logging
# ============================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO)
LOG_LEVEL=INFO

# Log file path (default: stderr)
# LOG_FILE=/path/to/skeptic.log
